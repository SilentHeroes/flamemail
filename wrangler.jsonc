{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "flamemail",
	"main": "src/worker/index.ts",
	"workers_dev": false,
	"compatibility_date": "2026-03-13",
	"compatibility_flags": ["nodejs_compat"],
	"assets": {
		"directory": "./dist/client",
		"binding": "ASSETS",
		"not_found_handling": "single-page-application",
		"run_worker_first": [
			"/api/*",
			"/ws"
		]
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "flamemail-db",
			"database_id": "295ee19f-2928-4cfc-b0e7-383204292158",
			"migrations_dir": "drizzle"
		}
	],
	"r2_buckets": [
		{
			"binding": "STORAGE",
			"bucket_name": "flamemail-emails"
		}
	],
	"kv_namespaces": [
		{
			"binding": "SESSIONS",
			"id": "2a4dd891ec4041a9a88a333490113c15"
		}
	],
	"durable_objects": {
		"bindings": [
			{
				"name": "INBOX_WS",
				"class_name": "InboxWebSocket"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": [
				"InboxWebSocket"
			]
		}
	],
	"triggers": {
		"crons": [
			"0 * * * *"
		]
	},
	"send_email": [
		{
			"name": "EMAIL_SEND"
		}
	],
	"observability": {
		"enabled": true
	},
	"routes": [
		{
			"pattern": "mail.easydemo.org",
			"custom_domain": true
		},
		{
			"pattern": "relay.orangeclouded-tmn.net",
			"custom_domain": true
		}
	]
}